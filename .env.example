# Server Config
NODE_ENV=development
PORT=4000
JWT_SECRET=your_super_secret_jwt_key_at_least_16_chars_long

# Database (Prisma)
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require&pgbouncer=true&connect_timeout=10"
DIRECT_URL="postgresql://username:password@host:5432/database?sslmode=require"

# Redis (Optional) - Leave empty to use in-memory fallback
# REDIS_URL=redis://localhost:6379

# Email / Plunk
PLUNK_API_KEY=your_plunk_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# Frontend URL (For CORS)
FRONTEND_URL=http://localhost:3000
